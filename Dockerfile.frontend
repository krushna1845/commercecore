FROM node:20-alpine AS build
WORKDIR /app
COPY commerce-frontend/package.json ./
COPY commerce-frontend/package-lock.json ./
RUN npm install
COPY commerce-frontend/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY commerce-frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
